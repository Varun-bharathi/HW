{
  "name": "hireflow-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:node": "tsx watch src/index.ts",
    "dev:python": "cd python_service && python resume_parser_api.py",
    "dev": "concurrently \"npm run dev:node\" \"npm run dev:python\"",
    "build": "tsc",
    "start": "node dist/src/index.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "pdf-parse": "^2.4.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^22.19.8",
    "concurrently": "^9.2.1",
    "prisma": "^7.4.1",
    "tsx": "^4.19.2",
    "typescript": "~5.6.2"
  },
  "description": "Express + Prisma + SQLite backend for the hiring platform.",
  "main": "index.js",
  "keywords": [],
  "author": "",
  "license": "ISC"
}
